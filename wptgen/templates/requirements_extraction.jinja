Extract the core normative test requirements for the following feature and specification.

<feature_definition>
  <feature_name>{{feature_name}}</feature_name>
  <feature_description>{{feature_description}}</feature_description>
</feature_definition>

{% if specs -%}
{% for url, content in specs.items() -%}
<spec_document url="{{url}}">
{{content}}
</spec_document>
{%- endfor %}
{%- endif %}

{% if mdn_contents -%}
{% for content in mdn_contents -%}
<mdn_document>
{{content}}
</mdn_document>
{% endfor -%}
{%- endif %}

{% if explainer_contents -%}
{% for url, content in explainer_contents.items() -%}
<explainer url="{{url}}">
{{content}}
</explainer>
{% endfor -%}
{%- endif %}
